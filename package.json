{
  "name": "start-cookie",
  "version": "0.0.0",
  "description": "Tiny isomorphic cookie helper for TanStack Start.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsdown --publint",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-start": ">=1.168.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugo-clemente/tanstack-start-cookie.git"
  },
  "devDependencies": {
    "@tanstack/react-start": "^1.168.0",
    "@types/bun": "latest",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "typescript": "^5.6.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  }
}
